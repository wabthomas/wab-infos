# Copier vers deploy/.env.deploy (non versionné) et adapter.
# Connexion SSH N0C / PlanetHoster

# Alias défini dans ~/.ssh/config (voir docs/deploy-ssh-windows.md)
DEPLOY_SSH_HOST=wab-noc

# Utilisateur cPanel (ex. wabth1234)
DEPLOY_REMOTE_USER=

# Racine du monorepo sur le serveur
DEPLOY_REMOTE_PATH=~/wab-infos
