{
  "name": "wab-infos",
  "version": "1.0.0",
  "private": true,
  "description": "Plateforme média professionnelle Wab-infos",
  "workspaces": [
    "apps/web",
    "apps/redaction",
    "apps/reader-android",
    "packages/*",
    "scripts/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:cms\" \"npm run dev:redaction\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:redaction": "npm run dev --workspace=apps/redaction",
    "dev:cms": "cd apps/cms && npm run develop",
    "build": "npm run build --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "build:redaction": "npm run pwa:fcm --workspace=apps/redaction && npm run build --workspace=apps/redaction",
    "build:redaction:pack": "npm run build:redaction && npm run pack:redaction-build",
    "build:web:low-mem": "npm run build:low-mem --workspace=apps/web",
    "build:web:pack": "npm run build:web && npm run pack:web-build",
    "reader-android:sync": "npm run cap:sync --workspace=apps/reader-android",
    "reader-android:open": "npm run cap:open --workspace=apps/reader-android",
    "reader-android:icons": "node scripts/reader-android-icons.mjs",
    "reader-android:splash": "node scripts/reader-android-splash.mjs",
    "reader-android:release": "node scripts/reader-android-release.mjs",
    "reader-android:install": "node scripts/reader-android-install.mjs",
    "reader-android:bundle": "node scripts/reader-android-bundle.mjs",
    "reader-android:copy-apk": "node scripts/copy-apk-to-web.mjs",
    "build:cms": "node scripts/build-cms-production.mjs",
    "build:cms:direct": "npm run build --prefix apps/cms",
    "start:web": "npm run start --workspace=apps/web",
    "start:redaction": "npm run start --workspace=apps/redaction",
    "start:cms": "npm run start --prefix apps/cms",
    "import:wordpress": "npm run import --workspace=@wab-infos/wordpress-import --",
    "import:images": "npm run backfill-images --workspace=@wab-infos/wordpress-import --",
    "import:meta": "npm run backfill-meta --workspace=@wab-infos/wordpress-import --",
    "optimize:media": "npm run optimize --workspace=@wab-infos/media-optimize --",
    "optimize:media:dry-run": "npm run dry-run --workspace=@wab-infos/media-optimize --",
    "optimize:media:server": "bash scripts/optimize-media-server.sh",
    "noc:install": "bash scripts/noc-npm-install.sh",
    "noc:install:redaction": "bash scripts/noc-npm-install.sh redaction",
    "noc:install:web": "bash scripts/noc-npm-install.sh web",
    "noc:check": "bash scripts/noc-npm-install.sh --check",
    "db:start": "powershell -ExecutionPolicy Bypass -File scripts/start-postgres.ps1",
    "setup:cms": "node scripts/setup-strapi-link.js",
    "postinstall": "node scripts/setup-strapi-link.js",
    "deploy:server": "bash scripts/deploy-server.sh",
    "deploy:setup": "powershell -ExecutionPolicy Bypass -File scripts/ssh-setup-windows.ps1",
    "deploy:web": "powershell -ExecutionPolicy Bypass -File scripts/deploy-remote.ps1 web",
    "deploy:redaction": "powershell -ExecutionPolicy Bypass -File scripts/deploy-remote.ps1 redaction",
    "deploy:cms": "powershell -ExecutionPolicy Bypass -File scripts/deploy-remote.ps1 cms",
    "deploy:all": "powershell -ExecutionPolicy Bypass -File scripts/deploy-remote.ps1 all",
    "deploy:remote:server": "powershell -ExecutionPolicy Bypass -File scripts/deploy-remote.ps1 exec -- \"cd ~/wab-infos && bash scripts/deploy-server.sh\"",
    "ssh:noc": "ssh wab-noc",
    "remote": "powershell -ExecutionPolicy Bypass -File scripts/deploy-remote.ps1 exec --",
    "pack:web-build": "node scripts/pack-web-build.mjs",
    "unpack:web-build": "node scripts/unpack-web-build.mjs",
    "pack:cms-build": "node scripts/pack-cms-build.mjs",
    "pack:redaction-build": "node scripts/pack-redaction-build.mjs",
    "unpack:redaction-build": "node scripts/unpack-redaction-build.mjs",
    "clean:build": "node scripts/clean-build-artifacts.mjs",
    "clean:packs": "node scripts/clean-build-artifacts.mjs --packs-only",
    "secrets": "node scripts/generate-secrets.js",
    "lint": "npm run lint --workspace=apps/web",
    "typecheck": "npm run typecheck --workspace=apps/web && npm run typecheck --workspace=apps/redaction"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
