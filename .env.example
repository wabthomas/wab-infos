# ===========================================
# Wab-infos — Variables d'environnement
# ===========================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://wab-infos.com
# Données de démo (Jean Mukendi, etc.) : true=forcer, false=interdire, absent=dev only
# USE_MOCK_DATA=false
NEXT_PUBLIC_SITE_NAME=Wab-infos
NEXT_PUBLIC_SITE_DESCRIPTION=Actualités RDC et international — Wab-infos

# --- Strapi CMS ---
STRAPI_URL=https://cms.app.wab-infos.com
STRAPI_API_TOKEN=your-strapi-api-token
NEXT_PUBLIC_STRAPI_URL=https://cms.app.wab-infos.com
# Timeout requêtes Strapi (ms) — évite les builds bloqués 60s+ si le CMS est lent
STRAPI_FETCH_TIMEOUT_MS=15000

# --- PostgreSQL ---
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=wab_infos
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

# --- JWT / Sécurité ---
JWT_SECRET=change-me-to-a-secure-random-string
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
API_TOKEN_SALT=change-me-api-token-salt
TRANSFER_TOKEN_SALT=change-me-transfer-token-salt
APP_KEYS=key1,key2,key3,key4

# --- Google ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Google Tag Manager (Search Console — méthode GTM, ex. GTM-NWZ4R8WZ)
NEXT_PUBLIC_GTM_ID=GTM-NWZ4R8WZ
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Créer les blocs dans AdSense → Annonces → Par unité → IDs numériques ci-dessous
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_IN_CONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_MID=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_MOBILE_STICKY=
NEXT_PUBLIC_GOOGLE_NEWS_PUBLICATION=wab-infos
# Reader Revenue Manager / Subscribe with Google (CMS Sync — code Publisher Center)
NEXT_PUBLIC_GOOGLE_SWG_PRODUCT_ID=CAowq7OyCw:openaccess
# Search Console — balise meta verification (sans guillemets)
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_TWITTER_HANDLE=@wabinfos

# --- Contact éditorial (pages légales, Google News) ---
NEXT_PUBLIC_CONTACT_EMAIL=contact@wab-infos.com
NEXT_PUBLIC_REDACTION_EMAIL=redaction@wab-infos.com
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_ADDRESS=Kinshasa
NEXT_PUBLIC_CONTACT_COUNTRY=République Démocratique du Congo
NEXT_PUBLIC_FOUNDED_YEAR=2010

# --- YouTube (Wab-infos TV) ---
# Chaîne : https://youtube.com/@wabinfostv
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=https://youtube.com/@wabinfostv
NEXT_PUBLIC_YOUTUBE_CHANNEL_HANDLE=wabinfostv
# ID technique pour l'embed direct sur /tv
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=UCjAepna3JBGPfzUBJRoKbCw
YOUTUBE_API_KEY=your-youtube-api-key

# --- PWA Push Notifications ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:redaction@wab-infos.com
# Alertes lecteurs à la publication (comme newsletter / réseaux sociaux)
PUSH_PUBLISH_ENABLED=true
PUSH_SEND_ON_PUBLISH=true
# Optionnel — par défaut REVALIDATION_SECRET
PUSH_SECRET=

# --- WordPress Import ---
WP_EXPORT_PATH=./data/wordpress-export.xml
WP_BASE_URL=https://wp.wab-infos.com
WP_UPLOADS_ORIGIN=https://wp.wab-infos.com
WP_UPLOADS_PATH=./data/uploads

# --- Cloudflare ---
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_API_TOKEN=your-api-token

# --- Revalidation ---
REVALIDATION_SECRET=change-me-revalidation-secret

# --- Newsletter ---
# Transport : smtp (défaut si configuré) ou brevo
NEWSLETTER_PROVIDER=smtp
NEWSLETTER_ENABLED=true
NEWSLETTER_SEND_ON_PUBLISH=true
NEWSLETTER_SENDER_EMAIL=newsletter@wab-infos.com
NEWSLETTER_SENDER_NAME=Wab-infos
NEWSLETTER_REPLY_TO=redaction@wab-infos.com
# PlanetHoster / cPanel — créer la boîte newsletter@ dans le panneau
SMTP_HOST=mail.wab-infos.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=newsletter@wab-infos.com
SMTP_PASS=
# Débit SMTP mutualisé (anti-spam / limites hébergeur)
NEWSLETTER_SMTP_CONCURRENCY=2
NEWSLETTER_SMTP_BATCH_DELAY_MS=400
# Optionnel — si NEWSLETTER_PROVIDER=brevo
BREVO_API_KEY=
# Optionnel — par défaut REVALIDATION_SECRET
NEWSLETTER_SECRET=

# --- Réseaux sociaux (publication auto à la mise en ligne) ---
SOCIAL_PUBLISH_ENABLED=true
SOCIAL_SEND_ON_PUBLISH=true
# Page Facebook — token longue durée avec permission pages_manage_posts
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# X (Twitter) — OAuth 1.0a (recommandé) OU Bearer token OAuth 2.0
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Alternative OAuth 2.0 (si pas de clés OAuth 1.0a)
X_BEARER_TOKEN=
# Optionnel — par défaut REVALIDATION_SECRET
SOCIAL_SECRET=
