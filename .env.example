# ===========================================
# Wab-infos — Variables d'environnement
# ===========================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://app.wab-infos.com
NEXT_PUBLIC_SITE_NAME=Wab-infos
NEXT_PUBLIC_SITE_DESCRIPTION=Actualités RDC et international — Wab-infos

# --- Strapi CMS ---
STRAPI_URL=https://cms.app.wab-infos.com
STRAPI_API_TOKEN=your-strapi-api-token
NEXT_PUBLIC_STRAPI_URL=https://cms.app.wab-infos.com

# --- PostgreSQL ---
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=wab_infos
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

# --- JWT / Sécurité ---
JWT_SECRET=change-me-to-a-secure-random-string
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
API_TOKEN_SALT=change-me-api-token-salt
TRANSFER_TOKEN_SALT=change-me-transfer-token-salt
APP_KEYS=key1,key2,key3,key4

# --- Google ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_NEWS_PUBLICATION=wab-infos

# --- YouTube (Wab-infos TV) ---
# Chaîne : https://youtube.com/@wabinfostv
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=https://youtube.com/@wabinfostv
NEXT_PUBLIC_YOUTUBE_CHANNEL_HANDLE=wabinfostv
# ID technique pour l'embed direct sur /tv
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=UCjAepna3JBGPfzUBJRoKbCw
YOUTUBE_API_KEY=your-youtube-api-key

# --- PWA Push Notifications ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# --- WordPress Import ---
WP_EXPORT_PATH=./data/wordpress-export.xml
WP_BASE_URL=https://wab-infos.com
WP_UPLOADS_PATH=./data/uploads

# --- Cloudflare ---
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_API_TOKEN=your-api-token

# --- Revalidation ---
REVALIDATION_SECRET=change-me-revalidation-secret
