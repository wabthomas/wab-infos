{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run pwa:fcm && next dev",
    "build": "npm run pwa:fcm && node scripts/build-production.mjs",
    "build:low-mem": "node scripts/build-production.mjs --low-mem",
    "typecheck": "tsc --noEmit",
    "build:direct": "next build --webpack",
    "build:turbo": "next build",
    "start": "next start",
    "lint": "eslint",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "pwa:fcm": "node ../../scripts/generate-firebase-messaging-config.mjs apps/web",
    "og:image": "node scripts/generate-og-image.mjs",
    "check:env": "node scripts/check-web-env.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.5",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.5",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@next/third-parties": "^16.2.9",
    "@tailwindcss/postcss": "^4",
    "@wab-infos/shared": "file:../../packages/shared",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "postcss": "^8.5.6",
    "qs": "^6.15.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "schema-dts": "^2.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.1",
    "@tailwindcss/oxide-linux-x64-musl": "4.3.1",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-linux-x64-musl": "1.32.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/qs": "^6.15.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "sharp": "^0.34.5",
    "typescript": "^5"
  }
}
