{
  "kind": "collectionType",
  "collectionName": "subscribers",
  "info": {
    "singularName": "subscriber",
    "pluralName": "subscribers",
    "displayName": "Abonné newsletter"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "unsubscribed"],
      "default": "active"
    },
    "unsubscribeToken": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "source": {
      "type": "string",
      "default": "web"
    },
    "subscribedAt": {
      "type": "datetime"
    },
    "unsubscribedAt": {
      "type": "datetime"
    }
  }
}
