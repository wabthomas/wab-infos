{
  "kind": "collectionType",
  "collectionName": "videos",
  "info": {
    "singularName": "video",
    "pluralName": "videos",
    "displayName": "Vidéo",
    "description": "Contenus Wab-infos TV"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "youtubeId": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["live", "replay", "emission", "podcast"],
      "default": "replay"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "duration": {
      "type": "string"
    },
    "show": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::show.show",
      "inversedBy": "videos"
    }
  }
}
