# URL publique de cette app (prod : https://redaction.app.wab-infos.com)
NEXT_PUBLIC_REDACTION_URL=http://localhost:3001

# Site lecteur (liens retour)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Wab-infos

# Strapi
STRAPI_URL=http://localhost:8090
NEXT_PUBLIC_STRAPI_URL=http://localhost:8090
STRAPI_API_TOKEN=

# Rôles Strapi users-permissions (noms exacts, séparés par des virgules — optionnel)
# REDACTION_SUPER_ADMIN_ROLES=SuperAdmin,Super Admin
# REDACTION_EDITOR_ROLES=Editor,Éditeur
# Admin / SuperAdmin : suppression de tout article ; rédacteurs : brouillons uniquement

# CMS admin (lien depuis login)
NEXT_PUBLIC_CMS_URL=http://localhost:8090

# Firebase push éditeurs
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
# Le fichier public/firebase-messaging-config.js est généré par npm run pwa:fcm (non versionné)

# Push lecteurs (publication article → notification APK)
PUSH_SEND_ON_PUBLISH=true
PUSH_SECRET=
# ou REVALIDATION_SECRET (même valeur que apps/web et apps/cms)
